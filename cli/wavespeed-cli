#!/usr/bin/env bash
# wavespeed-cli — thin shim that runs the bundled CLI inside its dedicated venv.
#
# This shim is what the SKILL.md files reference, regardless of host agent.
# It looks up the venv created by install.sh at:
#     ~/.local/share/wavespeed-skill/venv
# and falls back to a system `python3` if you skipped the venv install.
set -euo pipefail

VENV_PY="${WAVESPEED_PY:-$HOME/.local/share/wavespeed-skill/venv/bin/python}"
CLI_PY="${WAVESPEED_CLI_PY:-$HOME/.local/share/wavespeed-skill/cli.py}"

if [ ! -x "$VENV_PY" ]; then
    if command -v python3 >/dev/null 2>&1; then
        VENV_PY="$(command -v python3)"
    else
        echo "wavespeed-cli: no Python interpreter found at $VENV_PY and no system python3" >&2
        echo "Run install.sh from https://github.com/wesleysimplicio/WaveSpeedAI-Skills" >&2
        exit 127
    fi
fi

if [ ! -f "$CLI_PY" ]; then
    echo "wavespeed-cli: cli.py not found at $CLI_PY" >&2
    echo "Run install.sh from https://github.com/wesleysimplicio/WaveSpeedAI-Skills" >&2
    exit 127
fi

exec "$VENV_PY" "$CLI_PY" "$@"
